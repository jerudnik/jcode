#!/usr/bin/env bash
set -euo pipefail

# Local safety rail for this fork's branch model.
#
# The authoritative maintenance loop is:
#   vendor/upstream -> distro/nix -> main
#
# Day-to-day custom Jcode work belongs on main. `distro/nix` is intentionally
# narrow: reusable flake/package/cache/CI glue only, and usually written by CI.
# This hook blocks the easy accidental push path while keeping an explicit escape
# hatch for maintenance.

remote_name="${1:-unknown}"
remote_url="${2:-}"

allow_vendor="${JCODE_ALLOW_VENDOR_UPSTREAM_PUSH:-0}"
allow_distro="${JCODE_ALLOW_DISTRO_NIX_PUSH:-0}"

blocked=0

while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/vendor/upstream)
      if [ "$allow_vendor" != "1" ]; then
        cat >&2 <<EOF
error: refusing to push vendor/upstream to $remote_name ($remote_url)

vendor/upstream is the clean upstream mirror. CI normally owns it.
If you are doing intentional fork maintenance, rerun with:

  JCODE_ALLOW_VENDOR_UPSTREAM_PUSH=1 git push ...

EOF
        blocked=1
      fi
      ;;
    refs/heads/distro/nix)
      if [ "$allow_distro" != "1" ]; then
        cat >&2 <<EOF
error: refusing to push distro/nix to $remote_name ($remote_url)

distro/nix is packaging/distribution only. Features, docs, behavior changes,
mobile/web/server work, and normal fork customizations belong on main.

If this is intentional packaging maintenance, rerun with:

  JCODE_ALLOW_DISTRO_NIX_PUSH=1 git push ...

If you accidentally committed feature work on distro/nix, move it instead:

  git switch main
  git cherry-pick <first-bad-commit>^..<last-bad-commit>

EOF
        blocked=1
      fi
      ;;
  esac
done

exit "$blocked"
